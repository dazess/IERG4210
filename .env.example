# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database
DATABASE_PATH=database.db

# Auth
COOKIE_SECURE=0
COOKIE_SAMESITE=Strict

# Admin & User defaults
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=AdminPass!123
DEFAULT_ADMIN_NAME=Admin
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=UserPass!123
DEFAULT_USER_NAME=User

# Stripe Configuration (Backend)
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Get this from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Stripe Configuration (Frontend/Vite)
# Same as STRIPE_PUBLIC_KEY above
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Merchant Configuration
MERCHANT_EMAIL=your-email@example.com

# API Configuration (used for webhook redirects)
API_BASE_URL=http://localhost:5173
